{
  "name": "@vauban/agent-sdk",
  "version": "0.8.2",
  "description": "Vauban agent primitives: loop, budget, routing, HITL, permissions, tracking, durable execution",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./proof": {
      "types": "./dist/proof/index.d.ts",
      "import": "./dist/proof/index.js",
      "default": "./dist/proof/index.js"
    },
    "./outcomes": {
      "types": "./dist/outcomes/index.d.ts",
      "import": "./dist/outcomes/index.js",
      "default": "./dist/outcomes/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "CONTRACT.md",
    "README.md",
    "docs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vauban-org/command-center.git",
    "directory": "packages/agent-sdk"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "biome check src/ tests/",
    "size": "node scripts/measure-size.mjs",
    "bench": "node --import tsx/esm bench/run.ts",
    "mutation": "stryker run",
    "api:extract": "api-extractor run --local --verbose",
    "api:check": "api-extractor run",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@opentelemetry/api": "^1.9.0",
    "bullmq": "^5.75.2",
    "ioredis": "^5.10.1",
    "pino": "^9.5.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@microsoft/api-documenter": "^7.30.5",
    "@microsoft/api-extractor": "^7.58.7",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.0.0",
    "fast-check": "^4.7.0",
    "tinybench": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "starknet": "^6.24.1"
  },
  "peerDependenciesMeta": {
    "starknet": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
